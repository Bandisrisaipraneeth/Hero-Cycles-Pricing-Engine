{
  "name": "hero-cycles-pricing-engine",
  "version": "1.0.0",
  "description": "Pricing engine for configurable bicycles with time-sensitive pricing",
  "main": "dist/web/server.js",
  "scripts": {
    "build": "npx tsc && node build.js",
    "start": "npm run build && node dist/web/server.js",
    "dev": "node dist/web/server.js",
    "cli": "node dist/cli/index.js",
    "test": "npx jest",
    "test:watch": "npx jest --watch",
    "clean": "npx rimraf dist"
  },
  "keywords": [
    "pricing",
    "bicycles",
    "configurator",
    "hero-cycles"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "rimraf": "^3.0.2",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "express": "^4.18.0"
  }
}
